{
  "methodology": {
    "difficulty_index": "difficulty_index = (0.65 * playoff_score + 0.35 * season_score) * bracket_discount",
    "simple_difficulty_index": "simple_difficulty_index = 0.50 * simple_playoff_score + 0.50 * simple_contender_dropout_score",
    "playoff_score": "playoff_score = impact-weighted opponent availability in the champion's actual playoff path",
    "simple_playoff_score": "simple_playoff_score = VORP-weighted opponent availability in the champion's actual playoff path",
    "series_availability": "series_availability = sum(vorp * games_played) / sum(vorp * series_length)",
    "season_score": "season_score = 0.55 * current_playoff_field_score + 0.45 * prior_year_threat_score",
    "simple_contender_dropout_score": "simple_contender_dropout_score = VORP-weighted availability of prior-year contender stars on teams that fell out of the current playoff field",
    "current_playoff_field_score": "current_playoff_field_score = VORP-weighted regular-season availability of current non-champion playoff-team stars",
    "prior_year_threat_score": "prior_year_threat_score = VORP-weighted current-season availability of prior-year playoff-team stars who remained a threat or were effectively removed by injury",
    "player_availability": "player_availability = min(games / expected_games, 1.0)",
    "bracket_discount": "bracket_discount is a proxy penalty for off-path playoff contenders whose late injuries materially softened the road to the title",
